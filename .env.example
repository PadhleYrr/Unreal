# UNREAL — Only 2 keys needed. That's it.

# ── LLM Brain — FREE ──────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=your_google_ai_studio_key

# ── Face Storage — FREE (512MB M0 cluster) ───────────────────────────────
# Get from: https://cloud.mongodb.com → free M0 cluster
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/unreal

# ── Frontend server port ──────────────────────────────────────────────────
PORT=3000

# NOTE: No Sarvam, no LiveKit, no OpenAI.
# STT  → webkitSpeechRecognition  (built into Chrome, free)
# TTS  → window.speechSynthesis   (built into Chrome, free)
# LLM  → Gemini API               (GOOGLE_API_KEY above)
